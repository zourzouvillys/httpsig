    "method": "POST",
    "url": "https://example.com/foo?param=Value&Pet=dog",
    "headers": [
      ["Host", "example.com"],
      ["Date", "Tue, 20 Apr 2021 02:07:55 GMT"],
      ["Content-Type", "application/json"],
