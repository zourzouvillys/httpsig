{
  "name": "httpsig-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Documentation site and interactive tool for httpsig (RFC 9421 / RFC 9530).",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "BASE_PATH=/httpsig node build.mjs",
    "build:local": "node build.mjs",
    "serve": "node serve.mjs",
    "start": "node build.mjs && node serve.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "gray-matter": "^4.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
