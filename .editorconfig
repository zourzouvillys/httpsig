root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 4

[*.go]
indent_style = tab

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_size = 2

[*.swift]
indent_size = 4

[*.{kt,kts}]
indent_size = 4

[Makefile]
indent_style = tab
